<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty scope="context" name="lokiUrl" source="loki.url" defaultValue="http://loki.monitoring.svc.cluster.local:3100/loki/api/v1/push"/>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="sales-service"/>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${lokiUrl}</url>
        </http>
        <labels>
            app=eventticketing
            service=${appName}
            level=%level
            env=k8s
        </labels>
        <structuredMetadata>off</structuredMetadata>
        <message class="com.github.loki4j.logback.JsonLayout">
            <loggerName>
                <fieldName>logger</fieldName>
                <targetLength>36</targetLength>
            </loggerName>
            <threadName>
                <fieldName>thread</fieldName>
            </threadName>
            <mdc>
                <noPrefix>true</noPrefix>
                <include>correlationId</include>
                <include>userId</include>
                <include>bookingId</include>
                <include>saleId</include>
                <include>routingKey</include>
            </mdc>
        </message>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOKI"/>
    </root>
</configuration>
