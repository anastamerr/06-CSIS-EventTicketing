{
  "title": "User Service",
  "uid": "user-service",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "User Service Errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({app=\"eventticketing\", service=\"user-service\", level=\"ERROR\"} | json [1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Booking Feign Calls",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"user-service\"} | json | message=~\".*Booking service.*\" [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "RabbitMQ User Events",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (routingKey) (count_over_time({app=\"eventticketing\", service=\"user-service\"} | json | routingKey=~\"user\\\\.registered|user\\\\.deactivated\" [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Booking Saga Consumer Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (routingKey) (count_over_time({app=\"eventticketing\", service=\"user-service\"} | json | routingKey=~\"booking\\\\.completed|booking\\\\.cancelled\" [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{job=\"user-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Latency P95 / P99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95 {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "refId": "B",
          "legendFormat": "p99 {{uri}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg_over_time(jvm_memory_used_bytes{job=\"user-service\", area=\"heap\"}[5m])",
          "refId": "A",
          "legendFormat": "heap used"
        },
        {
          "expr": "avg_over_time(jvm_memory_max_bytes{job=\"user-service\", area=\"heap\"}[5m])",
          "refId": "B",
          "legendFormat": "heap max"
        }
      ]
    }
  ]
}
