{
  "title": "User Service",
  "uid": "user-service",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "User Service Errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"user-service\", level=\"ERROR\"} | json [1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "RabbitMQ Event Audit (user.registered / user.deactivated)",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"eventticketing\", service=\"user-service\"} | json | routingKey =~ \"user\\\\.registered|user\\\\.deactivated\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Booking Saga Consumer Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"eventticketing\", service=\"user-service\"} | json | routingKey =~ \"booking\\\\.completed|booking\\\\.cancelled\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{job=\"user-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Latency P95 / P99 (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95 {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"user-service\"}[5m])))",
          "refId": "B",
          "legendFormat": "p99 {{uri}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "JVM Heap Usage (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"user-service\", area=\"heap\"}",
          "refId": "A",
          "legendFormat": "heap used"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"user-service\", area=\"heap\"}",
          "refId": "B",
          "legendFormat": "heap max"
        }
      ]
    }
  ]
}
