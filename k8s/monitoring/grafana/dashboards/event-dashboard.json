{
  "title": "Event Service",
  "uid": "event-service",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["eventticketing", "event-service"],
  "panels": [
    {
      "id": 1,
      "title": "Event Service Error Logs",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "count_over_time({app=\"eventticketing\", service=\"event-service\", level=\"ERROR\"} | json [1m])"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Event RabbitMQ Publishes",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum by (routingKey) (count_over_time({app=\"eventticketing\", service=\"event-service\"} | json | routingKey=~\"event.status-changed|event.rated\" [5m]))"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
    },
    {
      "id": 3,
      "title": "Event Feign Outcomes",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum by (level) (count_over_time({app=\"eventticketing\", service=\"event-service\"} | json | message=~\".*Feign.*\" [5m]))"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
    },
    {
      "id": 4,
      "title": "Event HTTP Request Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{job=\"event-service\"}[5m]))"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
    },
    {
      "id": 5,
      "title": "Event HTTP P95 Latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"event-service\"}[5m])))"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
    },
    {
      "id": 6,
      "title": "Event JVM Heap Used",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
            {"expr": "avg_over_time(jvm_memory_used_bytes{job=\"event-service\", area=\"heap\"}[5m])"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}
    }
  ]
}
