{
  "title": "Booking Service",
  "uid": "booking-service",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "tags": ["eventticketing", "booking-service"],
  "panels": [
    {
      "id": 1,
      "title": "Booking HTTP Request Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{job=\"booking-service\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Booking HTTP P95 Latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"booking-service\"}[5m])))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
    },
    {
      "id": 3,
      "title": "Booking JVM Heap Used",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"booking-service\", area=\"heap\"})",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
    },
    {
      "id": 4,
      "title": "Booking Error Logs",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({app=\"eventticketing\", service=\"booking-service\", level=\"ERROR\"} | json [1m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
    },
    {
      "id": 5,
      "title": "Booking Feign Activity",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"booking-service\"} | json | message=~\".*Feign.*\" [5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
    },
    {
      "id": 6,
      "title": "Booking Event Logs",
      "type": "timeseries",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"eventticketing\", service=\"booking-service\"} | json | message=~\".*booking\\\\.(placed|completed|cancelled).*\" [5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}
    }
  ]
}
