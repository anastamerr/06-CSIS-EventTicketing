<configuration>
    <springProperty scope="context" name="lokiUrl" source="loki.url" defaultValue="http://loki.monitoring.svc.cluster.local:3100/loki/api/v1/push"/>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="ticket-service"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} [%X{correlationId:-}] - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${lokiUrl}</url>
        </http>
        <labels>
            app=eventticketing
            service=${appName}
            level=%level
            env=k8s
        </labels>
        <structuredMetadata>off</structuredMetadata>
        <message class="com.github.loki4j.logback.JsonLayout">
            <loggerName>
                <fieldName>logger</fieldName>
                <targetLength>36</targetLength>
            </loggerName>
            <threadName>
                <fieldName>thread</fieldName>
            </threadName>
            <mdc>
                <noPrefix>true</noPrefix>
                <include>correlationId</include>
                <include>bookingId</include>
                <include>ticketId</include>
                <include>eventId</include>
                <include>routingKey</include>
            </mdc>
        </message>
    </appender>
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOKI"/>
    </root>
</configuration>
